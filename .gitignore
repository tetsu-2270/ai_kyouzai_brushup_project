__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.env
.claude/settings.local.json
.DS_Store

# 利用者投入データ・生成物置き場。Git管理対象外（README「input/output方針」参照）
input/
output/

# 実行ログ置き場。logs/ディレクトリ自体はGit管理対象、ログファイル本体は対象外
# （README「ログ出力仕様」・docs/04_output_spec.md「プロジェクト標準output構成」参照）
logs/*
!logs/.gitkeep

# 検証エビデンス置き場（logs/evidence/<run_id>/）。ディレクトリ自体はGit管理対象、
# 実行結果本体（manifest.json/summary.md/コマンドログ/latest.json等）は対象外
# （docs/04_output_spec.md「検証エビデンス」参照）
!logs/evidence/
logs/evidence/*
!logs/evidence/.gitkeep

# 仮想環境
.venv/
venv/

# 配布用ZIP（scripts/make_release_zip.sh で生成）
*.zip

# Apple Vision OCRヘルパー（tools/apple_vision_ocr/）のSwiftビルド成果物。
# Swiftソース・Package.swift・ビルドスクリプトはGit管理対象、ビルド済みバイナリは対象外
# （scripts/build_apple_vision_ocr.sh で毎回ローカルビルドする想定）
tools/apple_vision_ocr/.build/
